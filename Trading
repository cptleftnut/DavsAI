<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DavsAI - Fremtidens Automatiserede Handel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #020617; /* slate-950 */
            color: #e2e8f0; /* slate-200 */
        }
        .gradient-text {
            background: linear-gradient(90deg, #2dd4bf, #38bdf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .cta-button {
            background-color: #14b8a6; /* teal-500 */
            transition: background-color 0.3s ease, transform 0.3s ease;
        }
        .cta-button:hover {
            background-color: #0d9488; /* teal-600 */
            transform: translateY(-2px);
        }
        .secondary-button {
            background-color: transparent;
            border: 1px solid #14b8a6; /* teal-500 */
            color: #14b8a6;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .secondary-button:hover {
            background-color: #14b8a6;
            color: #ffffff;
        }
        .glass-card {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(30, 41, 59, 0.5);
        }
        .faq-item .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.5s ease-in-out; }
        .faq-item.open .faq-answer { max-height: 500px; }
        .faq-item.open .faq-icon { transform: rotate(45deg); }
        .faq-icon { transition: transform 0.3s ease; }
        
        /* Modal styles */
        .modal-backdrop { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0.7); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: opacity 0.3s ease, visibility 0.3s ease; }
        .modal-backdrop.active { opacity: 1; visibility: visible; }
        .modal-content { transform: scale(0.95); transition: transform 0.3s ease; }
        .modal-backdrop.active .modal-content { transform: scale(1); }

        /* Animation for live feed */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .trade-item-enter { animation: fadeIn 0.5s ease forwards; }

        /* Profit/Loss flash animations */
        @keyframes flash-green-text { 0% { color: #4ade80; } 100% { color: inherit; } }
        @keyframes flash-red-text { 0% { color: #f87171; } 100% { color: inherit; } }
        .flash-green { animation: flash-green-text 1s ease; }
        .flash-red { animation: flash-red-text 1s ease; }
        .text-profit { color: #4ade80; }
        .text-loss { color: #f87171; }
        
        /* Tab styles */
        .tab-button {
            background-color: transparent;
            border-bottom: 2px solid transparent;
            transition: border-color 0.3s ease, color 0.3s ease;
        }
        .tab-button.active {
            color: #14b8a6;
            border-bottom-color: #14b8a6;
        }
    </style>
</head>
<body class="antialiased">

