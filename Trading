    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // --- STATE MANAGEMENT ---
            let accountState = {
                isLoggedIn: false,
                balance: 0,
                dailyPnl: 0,
                lockedEarnings: 0,
                activeLocks: [],
                tradeInterval: null,
                lockCheckInterval: null,
                performanceData: [],
                transactionHistory: [],
                totalTrades: 0,
                profitableTrades: 0,
            };

            // --- UI ELEMENTS ---
            const landingPage = document.getElementById('landing-page');
            const tradingDashboard = document.getElementById('trading-dashboard');
            const authButtons = document.getElementById('auth-buttons');
            const dashboardButtonContainer = document.getElementById('dashboard-button-container');
            const headerBalanceEl = document.getElementById('header-balance');
            const mobileMenu = document.getElementById('mobile-menu');
            const mobileMenuButton = document.getElementById('mobile-menu-button');
            
            // Dashboard UI
            const balanceEl = document.getElementById('dashboard-total-balance');
            const pnlEl = document.getElementById('dashboard-daily-pnl');
            const winRateEl = document.getElementById('dashboard-win-rate');
            const totalTradesEl = document.getElementById('dashboard-total-trades');
            const liveFeedEl = document.getElementById('live-feed');
            const historyBodyEl = document.getElementById('transaction-history-body');

            // HYIP UI
            const lockedSummaryEl = document.getElementById('dashboard-locked-earnings-summary');
            const lockAmountInput = document.getElementById('lock-amount');
            const lockPeriodSelect = document.getElementById('lock-period');
            const compoundToggle = document.getElementById('compound-toggle');
            const startLockButton = document.getElementById('start-lock-button');
            const activeLocksListEl = document.getElementById('active-locks-list');
            const lockErrorEl = document.getElementById('lock-error');

            // Modal UI
            const modal = document.getElementById('signup-modal');
            const openModalButtons = document.querySelectorAll('.open-signup-modal');
            const closeModalButton = document.getElementById('close-modal-button');
            const signupForm = document.getElementById('signup-form');

            // Charts
            let landingPageChart, performanceChart;

            // --- FORMATTERS ---
            const currencyFormatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
            const dateTimeFormatter = new Intl.DateTimeFormat('da-DK', { dateStyle: 'short', timeStyle: 'medium' });

            // --- INITIALIZATION ---
            function initializeLandingPageChart() {
                const ctx = document.getElementById('liveChart');
                if (ctx && !landingPageChart) {
                    let lastDate = Date.now();
                    const initialData = Array.from({ length: 40 }, (_, i) => {
                        lastDate -= 60000;
                        return { x: lastDate, y: 150 + Math.random() * 20 - 10 + i * 0.5 };
                    }).reverse();
                    landingPageChart = new Chart(ctx, {
                        type: 'line',
                        data: { datasets: [{ data: initialData, borderColor: '#14b8a6', backgroundColor: 'rgba(20, 184, 166, 0.1)', borderWidth: 2, pointRadius: 0, tension: 0.4, fill: true }] },
                        options: { responsive: true, scales: { x: { display: false }, y: { display: false } }, plugins: { legend: { display: false } } }
                    });
                    setInterval(() => {
                        if (landingPageChart) {
                            const lastPoint = landingPageChart.data.datasets[0].data.slice(-1)[0];
                            const newPoint = { x: Date.now(), y: lastPoint.y + Math.random() * 4 - 2 };
                            landingPageChart.data.datasets[0].data.push(newPoint);
                            landingPageChart.data.datasets[0].data.shift();
                            landingPageChart.update('quiet');
                        }
                    }, 2000);
                }
            }

            function initializePerformanceChart() {
                const ctx = document.getElementById('performanceChart');
                if (ctx && !performanceChart) {
                    performanceChart = new Chart(ctx, {
                        type: 'line',
                        data: { datasets: [{ label: 'Kontosaldo', data: accountState.performanceData, borderColor: '#2dd4bf', backgroundColor: 'rgba(45, 212, 191, 0.1)', borderWidth: 2, pointRadius: 0, tension: 0.1, fill: true }] },
                        options: { responsive: true, scales: { x: { type: 'timeseries', time: { unit: 'minute' }, ticks: { color: '#94a3b8' }, grid: { color: 'rgba(148, 163, 184, 0.1)' } }, y: { ticks: { color: '#94a3b8', callback: value => currencyFormatter.format(value) }, grid: { color: 'rgba(148, 163, 184, 0.1)' } } }, plugins: { legend: { display: false } } }
                    });
                }
            }

            // --- UI UPDATE & RENDERING ---
            function updateDashboardSummary() {
                balanceEl.textContent = currencyFormatter.format(accountState.balance);
                pnlEl.textContent = currencyFormatter.format(accountState.dailyPnl);
                pnlEl.className = `text-3xl font-bold mt-2 ${accountState.dailyPnl >= 0 ? 'text-profit' : 'text-loss'}`;
                totalTradesEl.textContent = accountState.totalTrades;
                const winRate = accountState.totalTrades > 0 ? (accountState.profitableTrades / accountState.totalTrades) * 100 : 0;
                winRateEl.textContent = `${winRate.toFixed(2)}%`;
                winRateEl.className = `text-3xl font-bold mt-2 ${winRate >= 50 ? 'text-profit' : 'text-loss'}`;
                headerBalanceEl.textContent = `Saldo: ${currencyFormatter.format(accountState.balance)}`;
            }
            
            function renderTransactionHistory() {
                historyBodyEl.innerHTML = '';
                [...accountState.transactionHistory].reverse().forEach(trade => {
                    const row = document.createElement('tr');
                    row.className = 'border-b border-slate-800 hover:bg-slate-800/50';
                    row.innerHTML = `
                        <td class="py-2 px-3">${dateTimeFormatter.format(trade.timestamp)}</td>
                        <td class="py-2 px-3 font-medium">${trade.market}</td>
                        <td class="py-2 px-3 ${trade.type === 'KØB' ? 'text-sky-400' : 'text-amber-400'}">${trade.type}</td>
                        <td class="py-2 px-3 text-right font-mono ${trade.pnl >= 0 ? 'text-profit' : 'text-loss'}">${currencyFormatter.format(trade.pnl)}</td>
                        <td class="py-2 px-3 text-right font-mono text-slate-400">${currencyFormatter.format(trade.balanceAfter)}</td>
                    `;
                    historyBodyEl.appendChild(row);
                });
            }

            function updateActiveLocksUI() {
                const totalLocked = accountState.activeLocks.reduce((sum, lock) => sum + lock.amount, 0);
                lockedSummaryEl.textContent = `Du har ${currencyFormatter.format(totalLocked)} låst i alt.`;

                if (accountState.activeLocks.length === 0) {
                    activeLocksListEl.innerHTML = `<p class="text-slate-500">Ingen aktive låse.</p>`;
                    return;
                }
                activeLocksListEl.innerHTML = accountState.activeLocks.map((lock, index) => {
                    const now = Date.now();
                    const isMatured = now >= lock.endDate;
                    const progress = isMatured ? 100 : Math.min(100, ((now - lock.startDate) / (lock.endDate - lock.startDate)) * 100);
                    
                    return `
                        <div class="glass-card rounded-lg p-4">
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-bold text-white">${currencyFormatter.format(lock.amount)} @ ${lock.rate}%</span>
                                <span class="text-slate-400">${lock.days} Dage</span>
                            </div>
                            <div class="w-full bg-slate-700 rounded-full h-2.5 mb-2">
                                <div class="bg-teal-500 h-2.5 rounded-full" style="width: ${progress}%"></div>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-slate-500">Udløber: ${new Date(lock.endDate).toLocaleDateString()}</span>
                                ${isMatured ? `<button data-lock-index="${index}" class="claim-lock-button cta-button text-xs font-bold py-1 px-3 rounded-md">Indløs</button>` : ''}
                            </div>
                        </div>
                    `;
                }).join('');
            }
            
            function switchTab(tabName) {
                document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
                document.querySelectorAll('.tab-button').forEach(button => button.classList.remove('active', 'text-teal-400'));
                
                document.getElementById(`tab-content-${tabName}`).classList.remove('hidden');
                document.querySelector(`button[data-tab='${tabName}']`).classList.add('active', 'text-teal-400');
            }

            function updateUI() {
                if (accountState.isLoggedIn) {
                    landingPage.classList.add('hidden');
                    tradingDashboard.classList.remove('hidden');
                    authButtons.classList.add('hidden');
                    dashboardButtonContainer.classList.remove('hidden');
                    if (!performanceChart) initializePerformanceChart();
                    updateDashboardSummary();
                    updateActiveLocksUI();
                    renderTransactionHistory();
                } else {
                    landingPage.classList.remove('hidden');
                    tradingDashboard.classList.add('hidden');
                    authButtons.classList.remove('hidden');
                    dashboardButtonContainer.classList.add('hidden');
                    if (performanceChart) { performanceChart.destroy(); performanceChart = null; }
                }
                updateMobileMenu();
            }

            function updateMobileMenu() {
                mobileMenu.innerHTML = accountState.isLoggedIn ? `
                    <div class="pt-4 pb-3 border-t border-slate-800 px-5">
                        <p class="text-base font-medium text-white">Saldo: ${currencyFormatter.format(accountState.balance)}</p>
                        <button id="mobile-logout-button" class="mt-3 block w-full text-center secondary-button font-semibold py-2 px-5 rounded-lg">Log Ud</button>
                    </div>` : `
                    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                        <a href="#trading-types" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800">Handelstyper</a>
                        <a href="#technology" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800">Teknologi</a>
                        <a href="#faq" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800">FAQ</a>
                    </div>
                    <div class="pt-4 pb-3 border-t border-slate-800 px-5">
                        <button class="open-signup-modal block w-full text-center cta-button text-white font-semibold py-2 px-5 rounded-lg shadow-lg mb-3">Kom i Gang</button>
                        <button class="open-signup-modal block w-full text-center text-sm font-medium text-slate-300 hover:text-white">Log Ind</button>
                    </div>`;
            }

            // --- SIMULATION LOGIC ---
            function startTrading() {
                stopTrading();
                accountState.tradeInterval = setInterval(() => {
                    const markets = ['BTC/USD', 'ETH/USD', 'EUR/USD', 'TSLA', 'AAPL', 'GBP/JPY'];
                    const market = markets[Math.floor(Math.random() * markets.length)];
                    const tradeType = Math.random() > 0.5 ? 'KØB' : 'SALG';
                    const isProfit = Math.random() > 0.45; // 55% win rate
                    const pnl = (accountState.balance * (Math.random() * 0.001)) * (isProfit ? 1 : -1);

                    accountState.balance += pnl;
                    accountState.dailyPnl += pnl;
                    accountState.totalTrades++;
                    if (isProfit) accountState.profitableTrades++;
                    
                    const trade = { timestamp: Date.now(), market, type: tradeType, pnl, balanceAfter: accountState.balance };
                    accountState.transactionHistory.push(trade);

                    accountState.performanceData.push({x: trade.timestamp, y: accountState.balance});
                    if(accountState.performanceData.length > 200) accountState.performanceData.shift();
                    if(performanceChart) performanceChart.update('quiet');

                    const newTradeEl = document.createElement('div');
                    newTradeEl.className = 'trade-item-enter grid grid-cols-3 gap-2 text-sm';
                    newTradeEl.innerHTML = `<span class="font-semibold">${market}</span><span class="${tradeType === 'KØB' ? 'text-sky-400' : 'text-amber-400'}">${tradeType}</span><span class="text-right font-mono ${isProfit ? 'text-profit' : 'text-loss'}">${currencyFormatter.format(pnl)}</span>`;
                    liveFeedEl.prepend(newTradeEl);
                    if (liveFeedEl.children.length > 50) liveFeedEl.lastElementChild.remove();
                    
                    updateDashboardSummary();
                    renderTransactionHistory();
                }, 2500);
            }

            function stopTrading() {
                clearInterval(accountState.tradeInterval);
                accountState.tradeInterval = null;
            }
            
            function startLockChecker() {
                stopLockChecker();
                accountState.lockCheckInterval = setInterval(updateActiveLocksUI, 5000); // Check for matured locks every 5s
            }
            
            function stopLockChecker() {
                clearInterval(accountState.lockCheckInterval);
                accountState.lockCheckInterval = null;
            }

            // --- EVENT HANDLERS ---
            function handleLogin(e) {
                e.preventDefault();
                const initialDeposit = parseFloat(document.getElementById('initial-deposit').value) || 1000;
                
                accountState = { ...accountState, isLoggedIn: true, balance: initialDeposit, dailyPnl: 0, totalTrades: 0, profitableTrades: 0, transactionHistory: [], performanceData: [{x: Date.now(), y: initialDeposit}] };
                
                localStorage.setItem('davsAIState', JSON.stringify(accountState));
                modal.classList.remove('active');
                updateUI();
                startTrading();
                startLockChecker();
            }

            function handleLogout() {
                stopTrading();
                stopLockChecker();
                accountState.isLoggedIn = false;
                localStorage.removeItem('davsAIState');
                updateUI();
            }

            function handleClaimLock(e) {
                if (!e.target.classList.contains('claim-lock-button')) return;
                const index = parseInt(e.target.dataset.lockIndex);
                const lock = accountState.activeLocks[index];
                
                if (lock && Date.now() >= lock.endDate) {
                    const profit = lock.amount * (lock.rate / 100);
                    const payout = lock.amount + profit;
                    
                    accountState.balance += payout;
                    // Note: lockedEarnings state is derived, so we just remove the lock
                    accountState.activeLocks.splice(index, 1);
                    
                    // Add a transaction for clarity
                    const trade = { timestamp: Date.now(), market: 'HYIP Indløsning', type: 'GEVINST', pnl: profit, balanceAfter: accountState.balance };
                    accountState.transactionHistory.push(trade);

                    updateUI();
                }
            }

            // --- EVENT LISTENERS BINDING ---
            document.getElementById('dashboard-tabs').addEventListener('click', e => {
                if (e.target.dataset.tab) switchTab(e.target.dataset.tab);
            });
            startLockButton.addEventListener('click', () => {
                const amount = parseFloat(lockAmountInput.value);
                lockErrorEl.textContent = '';
                if (isNaN(amount) || amount <= 0) { lockErrorEl.textContent = 'Indtast venligst et gyldigt beløb.'; return; }
                if (amount > accountState.balance) { lockErrorEl.textContent = 'Du har ikke nok midler på din saldo.'; return; }
                const selectedOption = lockPeriodSelect.options[lockPeriodSelect.selectedIndex];
                accountState.balance -= amount;
                accountState.activeLocks.push({ amount, days: parseInt(selectedOption.value), rate: parseFloat(selectedOption.dataset.rate), isCompounding: compoundToggle.checked, startDate: Date.now(), endDate: Date.now() + parseInt(selectedOption.value) * 24 * 60 * 60 * 1000 });
                lockAmountInput.value = '';
                updateUI();
            });
            activeLocksListEl.addEventListener('click', handleClaimLock);
            mobileMenuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
            document.body.addEventListener('click', (e) => {
                if (e.target.id === 'logout-button' || e.target.id === 'mobile-logout-button') handleLogout();
                if (e.target.classList.contains('open-signup-modal')) modal.classList.add('active');
            });
            closeModalButton.addEventListener('click', () => modal.classList.remove('active'));
            modal.addEventListener('click', (e) => { if(e.target === modal) modal.classList.remove('active'); });
            signupForm.addEventListener('submit', handleLogin);
            
            const faqContainer = document.getElementById('faq-container');
            if (faqContainer) faqContainer.addEventListener('click', (e) => {
                const qButton = e.target.closest('.faq-question');
                if (!qButton) return;
                const faqItem = qButton.parentElement;
                const wasOpen = faqItem.classList.contains('open');
                faqContainer.querySelectorAll('.faq-item.open').forEach(item => item.classList.remove('open'));
                if (!wasOpen) faqItem.classList.add('open');
            });

            // --- SESSION MANAGEMENT ---
            function checkSession() {
                const savedState = localStorage.getItem('davsAIState');
                if (savedState) {
                    accountState = JSON.parse(savedState);
                    if(accountState.isLoggedIn) {
                        updateUI();
                        startTrading();
                        startLockChecker();
                    }
                } else {
                    initializeLandingPageChart();
                    updateMobileMenu();
                }
            }
            checkSession();
        });
    </script>
</body>
</html>

